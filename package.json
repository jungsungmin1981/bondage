{
  "name": "bondage",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "turbo format",
    "typecheck": "turbo typecheck",
    "auth:generate": "pnpm --filter @workspace/auth exec auth generate",
    "auth:migrate": "pnpm --filter @workspace/auth exec auth migrate",
    "db:generate": "pnpm --filter @workspace/db exec drizzle-kit generate",
    "db:migrate": "pnpm --filter @workspace/db run db:migrate",
    "db:studio": "pnpm --filter @workspace/db exec drizzle-kit studio",
    "db:clear-all-posts-and-comments": "pnpm --filter @workspace/db run db:clear-all-posts-and-comments",
    "db:delete-all-users": "pnpm --filter @workspace/db run db:delete-all-users",
    "clear-s3": "pnpm --filter web run clear-s3",
    "clear-all": "pnpm db:clear-all-posts-and-comments && pnpm clear-s3"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.1.18"
  },
  "devDependencies": {
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.8.8",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@9.0.6",
  "engines": {
    "node": ">=20"
  }
}