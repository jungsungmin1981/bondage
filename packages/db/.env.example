# ===========================================
# packages/db 전용 환경 변수 샘플
# 이 파일을 복사해 .env 로 저장한 뒤 값을 채워 사용하세요.
# ===========================================

# --- 데이터베이스 (Drizzle Studio / migrate / generate) ---
# Supabase: Project Settings > Database > Connection string (URI)
# DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-1-ap-northeast-2.pooler.supabase.com:6543/postgres"

# 또는 host / port / user / password / database 분리 (포트 변경 시 편함)
# DATABASE_HOST="aws-1-ap-northeast-2.pooler.supabase.com"
# DATABASE_PORT="6543"
# DATABASE_USER="postgres.[project-ref]"
# DATABASE_PASSWORD="your-password"
# DATABASE_NAME="postgres"

# --- 시드 스크립트 (임의 좋아요 넣기) ---
# packages/db 에 .env 또는 레포 루트/.env 에 위 DB 변수 설정 후:
#   pnpm db:seed-post-likes
