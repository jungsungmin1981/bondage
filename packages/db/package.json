{
  "name": "@workspace/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/migrate-with-env.ts",
    "db:add-username-columns": "tsx scripts/add-username-columns.ts",
    "db:ensure-member-profiles": "tsx scripts/ensure-member-profiles.ts",
    "db:ensure-users-member-type": "tsx scripts/ensure-users-member-type.ts",
    "db:ensure-member-profiles-detail-columns": "tsx scripts/ensure-member-profiles-detail-columns.ts",
    "db:ensure-member-profiles-gender": "tsx scripts/ensure-member-profiles-gender.ts",
    "db:ensure-member-profiles-card-image-url": "tsx scripts/ensure-member-profiles-card-image-url.ts",
    "db:ensure-rigger-photos-visibility-after-approval": "tsx scripts/ensure-rigger-photos-visibility-after-approval.ts",
    "db:ensure-direct-messages": "tsx scripts/ensure-direct-messages.ts",
    "db:ensure-dm-tables": "tsx scripts/ensure-dm-tables.ts",
    "db:seed-post-likes": "tsx scripts/seed-post-likes.ts",
    "db:seed-bunny-users": "tsx scripts/seed-bunny-users.ts",
    "db:clear-bunny-approvals": "tsx scripts/clear-bunny-approvals.ts",
    "db:studio": "drizzle-kit studio --host localhost --port 4983",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "db:ensure-class-posts": "tsx scripts/ensure-class-posts.ts",
    "db:ensure-class-challenges": "tsx scripts/ensure-class-challenges.ts",
    "db:ensure-class-challenge-approvals": "tsx scripts/ensure-class-challenge-approvals.ts",
    "db:ensure-approval-comment-columns": "tsx scripts/ensure-approval-comment-columns.ts"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.38.0",
    "postgres": "^3.4.4"
  },
  "devDependencies": {
    "@types/node": "^25.1.0",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "drizzle-kit": "^0.30.0",
    "eslint": "^9.39.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
