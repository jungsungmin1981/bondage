# ===========================================
# Bondage 모노레포 환경 변수 샘플
# 이 파일을 복사해 .env 로 저장한 뒤 값을 채워 사용하세요.
# ===========================================

# --- 데이터베이스 (Drizzle + Better Auth 공용) ---
# 방법 1: 연결 문자열 한 줄 (Supabase: Project Settings > Database > Connection string URI)
# DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-1-ap-northeast-2.pooler.supabase.com:6543/postgres"

# 방법 2: host / port / user / password / db 분리 (포트 등 설정 변경 시 편함)
# DATABASE_HOST="aws-1-ap-northeast-2.pooler.supabase.com"
# DATABASE_PORT="6543"
# DATABASE_USER="postgres.[project-ref]"
# DATABASE_PASSWORD="your-password"
# DATABASE_NAME="postgres"
# DB Max client connections reached 방지: 풀 최대 연결 수 (기본 5). 여유 있으면 10 등으로 올려도 됨.
# DATABASE_POOL_MAX="5"

# --- Better Auth (선택) ---
# 세션/쿠키 서명용 시크릿. 미설정 시 기본값 사용 가능.
# BETTER_AUTH_SECRET="your-random-secret-at-least-32-chars"

# --- 소셜 로그인 (선택, 사용 시에만 추가) ---
# GITHUB_CLIENT_ID=""
# GITHUB_CLIENT_SECRET=""
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# 카카오 로그인 (Redirect URI: /api/auth/oauth2/callback/kakao)
# KAKAO_CLIENT_ID=""
# KAKAO_CLIENT_SECRET=""

# 네이버 로그인 (Callback URL: /api/auth/oauth2/callback/naver)
# NAVER_CLIENT_ID=""
# NAVER_CLIENT_SECRET=""

# 구글 로그인 (Redirect URI: /api/auth/callback/google)
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
# (운영 시) BETTER_AUTH_URL="https://your-domain.com"

# --- 이메일 발송 (비밀번호 재설정, 아이디 찾기) ---
# Resend API Key: https://resend.com 에서 발급. 미설정 시 메일 미발송(비밀번호/아이디 찾기 동작은 하되 메일만 안 감).
# RESEND_API_KEY="re_xxxx"
# 발신 주소 (Resend 무료는 onboarding@resend.dev 또는 검증 도메인만 가능)
# RESEND_FROM="Bondage <onboarding@resend.dev>"

# --- 관리자 (선택) ---
# 관리자 권한: 리거 승인, 버니 승인요청 전체 보기 등. 이메일 또는 아이디 중 하나만 맞으면 됨.
# ADMIN_EMAIL="admin@example.com"
# ADMIN_USERNAME="admin"
# ADMIN_NICKNAME="관리자"  # 주 관리자 표시 이름 고정 (운영진 목록·상세·상단 메뉴)
